#include<stdio.h>

void main()
{
    int n,binary=0,place=1,r;

    printf("Enter decimal number: ");
    scanf("%d",&n);

    while(n>0)
    {
        r=n%2;
        binary=binary+r*place;
        place=place*10;
        n=n/2;
    }

    printf("Binary = %d",binary);
}
//question 22
#include<stdio.h>

void main()
{
    int bin,dec=0,base=1,r;

    printf("Enter binary number: ");
    scanf("%d",&bin);

    while(bin>0)
    {
        r=bin%10;
        dec=dec+r*base;
        base=base*2;
        bin=bin/10;
    }

    printf("Decimal = %d",dec);
}
