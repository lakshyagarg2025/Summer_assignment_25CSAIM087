#include<stdio.h>

void main()
{
    int n,count=0;

    printf("Enter number: ");
    scanf("%d",&n);

    while(n>0)
    {
        if(n%2==1)
            count++;

        n=n/2;
    }

    printf("Set Bits = %d",count);
}
