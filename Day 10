#include<stdio.h>

void main()
{
    int i,j,n;

    printf("Enter rows: ");
    scanf("%d",&n);

    for(i=1;i<=n;i++)
    {
        for(j=1;j<=i;j++)
            printf("%d",j);

        for(j=i-1;j>=1;j--)
            printf("%d",j);

        printf("\n");
    }
}
//question 40
#include<stdio.h>

void main()
{
    int i,j,n;

    printf("Enter rows: ");
    scanf("%d",&n);

    for(i=1;i<=n;i++)
    {
        for(j=0;j<i;j++)
            printf("%c",'A'+j);

        for(j=i-2;j>=0;j--)
            printf("%c",'A'+j);

        printf("\n");
    }
}
