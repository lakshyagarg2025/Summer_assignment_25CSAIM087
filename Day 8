#include<stdio.h>

void main()
{
    int i,j,n;

    printf("Enter number of rows: ");
    scanf("%d",&n);

    for(i=1;i<=n;i++)
    {
        for(j=0;j<i;j++)
        {
            printf("%c",'A'+j);
        }
        printf("\n");
    }
}
