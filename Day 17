/* Question 65 : Merge Two Arrays */

#include<stdio.h>

void main()
{
    int a[50],b[50],c[100];
    int n1,n2,i;

    scanf("%d",&n1);

    for(i=0;i<n1;i++)
        scanf("%d",&a[i]);

    scanf("%d",&n2);

    for(i=0;i<n2;i++)
        scanf("%d",&b[i]);

    for(i=0;i<n1;i++)
        c[i]=a[i];

    for(i=0;i<n2;i++)
        c[n1+i]=b[i];

    for(i=0;i<n1+n2;i++)
        printf("%d ",c[i]);
}

/* Question 66 : Union of Two Arrays */

#include<stdio.h>

void main()
{
    int a[50],b[50];
    int n1,n2,i,j,flag;

    scanf("%d",&n1);
    for(i=0;i<n1;i++)
        scanf("%d",&a[i]);

    scanf("%d",&n2);
    for(i=0;i<n2;i++)
        scanf("%d",&b[i]);

    for(i=0;i<n1;i++)
        printf("%d ",a[i]);

    for(i=0;i<n2;i++)
    {
        flag=0;

        for(j=0;j<n1;j++)
        {
            if(b[i]==a[j])
            {
                flag=1;
                break;
            }
        }

        if(flag==0)
            printf("%d ",b[i]);
    }
}

/* Question 67 : Intersection of Arrays */

#include<stdio.h>

void main()
{
    int a[50],b[50];
    int n1,n2,i,j;

    scanf("%d",&n1);
    for(i=0;i<n1;i++)
        scanf("%d",&a[i]);

    scanf("%d",&n2);
    for(i=0;i<n2;i++)
        scanf("%d",&b[i]);

    for(i=0;i<n1;i++)
    {
        for(j=0;j<n2;j++)
        {
            if(a[i]==b[j])
            {
                printf("%d ",a[i]);
                break;
            }
        }
    }
}

