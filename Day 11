int max(int a,int b)
{
    if(a>b)
        return a;
    else
        return b;
}

void main()
{
    int x,y;

    printf("Enter two numbers: ");
    scanf("%d%d",&x,&y);

    printf("Maximum = %d",max(x,y));
}
//question 43
#include<stdio.h>

int prime(int n)
{
    int i;

    if(n<2)
        return 0;

    for(i=2;i<=n/2;i++)
    {
        if(n%i==0)
            return 0;
    }

    return 1;
}

void main()
{
    int n;

    printf("Enter number: ");
    scanf("%d",&n);

    if(prime(n))
        printf("Prime Number");
    else
        printf("Not Prime Number");
}
//question 44
#include<stdio.h>

long int fact(int n)
{
    int i;
    long int f=1;

    for(i=1;i<=n;i++)
        f=f*i;

    return f;
}

void main()
{
    int n;

    printf("Enter number: ");
    scanf("%d",&n);

    printf("Factorial = %ld",fact(n));
}
