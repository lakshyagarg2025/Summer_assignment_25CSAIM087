#include<stdio.h>
#include<conio.h>

void main()
{
    int a, b, max;

    printf("Enter two numbers: ");
    scanf("%d%d", &a, &b);

    max = (a > b) ? a : b;

    while(1)
    {
        if(max % a == 0 && max % b == 0)
        {
            printf("LCM = %d", max);
            break;
        }
        max++;
    }

    getch();
}
