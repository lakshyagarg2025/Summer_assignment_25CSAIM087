/* Question 73 : Matrix Addition */

#include<stdio.h>

void main()
{
    int a[10][10],b[10][10],c[10][10];
    int r,col,i,j;

    scanf("%d%d",&r,&col);

    for(i=0;i<r;i++)
        for(j=0;j<col;j++)
            scanf("%d",&a[i][j]);

    for(i=0;i<r;i++)
        for(j=0;j<col;j++)
            scanf("%d",&b[i][j]);

    for(i=0;i<r;i++)
        for(j=0;j<col;j++)
            c[i][j]=a[i][j]+b[i][j];

    for(i=0;i<r;i++)
    {
        for(j=0;j<col;j++)
            printf("%d ",c[i][j]);
        printf("\n");
    }
}

/* Question 74 : Matrix Subtraction */

