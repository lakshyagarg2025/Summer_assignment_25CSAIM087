/* Question 75 : Transpose Matrix */

#include<stdio.h>

void main()
{
    int a[10][10];
    int r,c,i,j;

    scanf("%d%d",&r,&c);

    for(i=0;i<r;i++)
    {
        for(j=0;j<c;j++)
            scanf("%d",&a[i][j]);
    }

    printf("Transpose Matrix:\n");

    for(i=0;i<c;i++)
    {
        for(j=0;j<r;j++)
            printf("%d ",a[j][i]);

        printf("\n");
    }
}

/* Question 76 : Find Diagonal Sum */

#include<stdio.h>

void main()
{
    int a[10][10];
    int n,i,j,sum=0;

    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        for(j=0;j<n;j++)
            scanf("%d",&a[i][j]);
    }

    for(i=0;i<n;i++)
        sum=sum+a[i][i];

    printf("Diagonal Sum = %d",sum);
}
