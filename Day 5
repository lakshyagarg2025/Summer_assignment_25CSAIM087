#include<stdio.h>

void main()
{
    int n,i,sum=0;

    printf("Enter number: ");
    scanf("%d",&n);

    for(i=1;i<n;i++)
    {
        if(n%i==0)
            sum=sum+i;
    }

    if(sum==n)
        printf("Perfect Number");
    else
        printf("Not Perfect Number");
}
//question 18
#include<stdio.h>

void main()
{
    int n,temp,r,sum=0,i,fact;

    printf("Enter number: ");
    scanf("%d",&n);

    temp=n;

    while(temp>0)
    {
        r=temp%10;
        fact=1;

        for(i=1;i<=r;i++)
            fact=fact*i;

        sum=sum+fact;
        temp=temp/10;
    }

    if(sum==n)
        printf("Strong Number");
    else
        printf("Not Strong Number");
}
