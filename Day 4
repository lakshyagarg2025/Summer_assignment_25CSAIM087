#include<stdio.h>

void main()
{
    int n,a=0,b=1,c,i;

    printf("Enter n: ");
    scanf("%d",&n);

    if(n==1)
        printf("Nth term = %d",a);
    else if(n==2)
        printf("Nth term = %d",b);
    else
    {
        for(i=3;i<=n;i++)
        {
            c=a+b;
            a=b;
            b=c;
        }
        printf("Nth term = %d",b);
    }
}
//question 15
#include<stdio.h>

void main()
{
    int n,temp,r,sum=0;

    printf("Enter number: ");
    scanf("%d",&n);

    temp=n;

    while(temp>0)
    {
        r=temp%10;
        sum=sum+r*r*r;
        temp=temp/10;
    }

    if(sum==n)
        printf("Armstrong Number");
    else
        printf("Not Armstrong Number");
}
//question 16
#include<stdio.h>

void main()
{
    int start,end,num,temp,r,sum;

    printf("Enter start and end: ");
    scanf("%d%d",&start,&end);

    for(num=start; num<=end; num++)
    {
        temp=num;
        sum=0;

        while(temp>0)
        {
            r=temp%10;
            sum=sum+r*r*r;
            temp=temp/10;
        }

        if(sum==num)
            printf("%d ",num);
    }
}
