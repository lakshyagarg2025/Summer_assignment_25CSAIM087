#include<stdio.h>

int perfect(int n)
{
    int i,sum=0;

    for(i=1;i<n;i++)
    {
        if(n%i==0)
            sum=sum+i;
    }

    return sum==n;
}

void main()
{
    int n;

    printf("Enter number: ");
    scanf("%d",&n);

    if(perfect(n))
        printf("Perfect Number");
    else
        printf("Not Perfect Number");
}
