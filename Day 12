#include<stdio.h>

int palindrome(int n)
{
    int rev=0,temp=n;

    while(temp>0)
    {
        rev=rev*10+temp%10;
        temp=temp/10;
    }

    return rev==n;
}

void main()
{
    int n;

    printf("Enter number: ");
    scanf("%d",&n);

    if(palindrome(n))
        printf("Palindrome");
    else
        printf("Not Palindrome");
}
// question 46
#include<stdio.h>

int armstrong(int n)
{
    int temp=n,r,sum=0;

    while(temp>0)
    {
        r=temp%10;
        sum=sum+r*r*r;
        temp=temp/10;
    }

    return sum==n;
}

void main()
{
    int n;

    printf("Enter number: ");
    scanf("%d",&n);

    if(armstrong(n))
        printf("Armstrong Number");
    else
        printf("Not Armstrong Number");
}
//question 47
#include<stdio.h>

int fib(int n)
{
    if(n<=1)
        return n;

    return fib(n-1)+fib(n-2);
}

void main()
{
    int n,i;

    printf("Enter terms: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
        printf("%d ",fib(i));
}
