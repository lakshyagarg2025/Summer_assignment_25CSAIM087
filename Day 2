//question 8
#include<stdio.h>
#include<conio.h>

void main()
{
    int n, temp, rev=0, r;

    printf("Enter a number: ");
    scanf("%d",&n);

    temp=n;

    while(n>0)
    {
        r=n%10;
        rev=rev*10+r;
        n=n/10;
    }

    if(temp==rev)
        printf("Palindrome Number");
    else
        printf("Not a Palindrome Number");

    getch();
}
