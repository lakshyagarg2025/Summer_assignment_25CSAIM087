/* Question 69 : Bubble Sort */

#include<stdio.h>

void main()
{
    int a[100],n,i,j,temp;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    for(i=0;i<n-1;i++)
    {
        for(j=0;j<n-1-i;j++)
        {
            if(a[j]>a[j+1])
            {
                temp=a[j];
                a[j]=a[j+1];
                a[j+1]=temp;
            }
        }
    }

    for(i=0;i<n;i++)
        printf("%d ",a[i]);
}

/* Question 70 : Selection Sort */

#include<stdio.h>

void main()
{
    int a[100],n,i,j,min,temp;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    for(i=0;i<n-1;i++)
    {
        min=i;

        for(j=i+1;j<n;j++)
        {
            if(a[j]<a[min])
                min=j;
        }

        temp=a[i];
        a[i]=a[min];
        a[min]=temp;
    }

    for(i=0;i<n;i++)
        printf("%d ",a[i]);
}

/* Question 71 : Binary Search */

#include<stdio.h>

void main()
{
    int a[100],n,i,key,low,high,mid;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    scanf("%d",&key);

    low=0;
    high=n-1;

    while(low<=high)
    {
        mid=(low+high)/2;

        if(a[mid]==key)
        {
            printf("Found at %d",mid);
            return;
        }

        if(a[mid]<key)
            low=mid+1;
        else
            high=mid-1;
    }

    printf("Not Found");
}

/* Question 72 : Sort Array in Descending Order */

#include<stdio.h>

void main()
{
    int a[100],n,i,j,temp;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    for(i=0;i<n-1;i++)
    {
        for(j=i+1;j<n;j++)
        {
            if(a[i]<a[j])
            {
                temp=a[i];
                a[i]=a[j];
                a[j]=temp;
            }
        }
    }

    for(i=0;i<n;i++)
        printf("%d ",a[i]);
}
