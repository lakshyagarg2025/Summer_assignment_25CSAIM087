/* Question 49 : Input and Display Array */

#include<stdio.h>

void main()
{
    int a[100],n,i;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    for(i=0;i<n;i++)
        printf("%d ",a[i]);
}

/* Question 50 : Sum and Average of Array */

#include<stdio.h>

void main()
{
    int a[100],n,i,sum=0;
    float avg;

    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
        sum+=a[i];
    }

    avg=(float)sum/n;

    printf("Sum=%d\nAverage=%.2f",sum,avg);
}

/* Question 51 : Largest and Smallest Element */

#include<stdio.h>

void main()
{
    int a[100],n,i,max,min;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    max=min=a[0];

    for(i=1;i<n;i++)
    {
        if(a[i]>max)
            max=a[i];

        if(a[i]<min)
            min=a[i];
    }

    printf("Largest=%d\nSmallest=%d",max,min);
}

/* Question 52 : Count Even and Odd Elements */

#include<stdio.h>

void main()
{
    int a[100],n,i,even=0,odd=0;

    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        scanf("%d",&a[i]);

        if(a[i]%2==0)
            even++;
        else
            odd++;
    }

    printf("Even=%d\nOdd=%d",even,odd);
}
