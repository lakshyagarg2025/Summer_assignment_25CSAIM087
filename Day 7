#include<stdio.h>

int fact(int n)
{
    if(n==0)
        return 1;
    return n*fact(n-1);
}

void main()
{
    int n;

    printf("Enter number: ");
    scanf("%d",&n);

    printf("Factorial = %d",fact(n));
}
//question 26
#include<stdio.h>

int fib(int n)
{
    if(n==0)
        return 0;
    if(n==1)
        return 1;

    return fib(n-1)+fib(n-2);
}

void main()
{
    int n,i;

    printf("Enter terms: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
        printf("%d ",fib(i));
}
//question 27
#include<stdio.h>

int sumDigit(int n)
{
    if(n==0)
        return 0;

    return n%10 + sumDigit(n/10);
}

void main()
{
    int n;

    printf("Enter number: ");
    scanf("%d",&n);

    printf("Sum = %d",sumDigit(n));
}
