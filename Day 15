/* Question 57 : Reverse Array */

#include<stdio.h>

void main()
{
    int a[100],n,i,temp;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    for(i=0;i<n/2;i++)
    {
        temp=a[i];
        a[i]=a[n-1-i];
        a[n-1-i]=temp;
    }

    for(i=0;i<n;i++)
        printf("%d ",a[i]);
}

/* Question 58 : Rotate Array Left by One Position */

#include<stdio.h>

void main()
{
    int a[100],n,i,temp;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    temp=a[0];

    for(i=0;i<n-1;i++)
        a[i]=a[i+1];

    a[n-1]=temp;

    for(i=0;i<n;i++)
        printf("%d ",a[i]);
}

/* Question 59 : Rotate Array Right by One Position */

#include<stdio.h>

void main()
{
    int a[100],n,i,temp;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    temp=a[n-1];

    for(i=n-1;i>0;i--)
        a[i]=a[i-1];

    a[0]=temp;

    for(i=0;i<n;i++)
        printf("%d ",a[i]);
}

/* Question 60 : Move Zeroes to End */

#include<stdio.h>

void main()
{
    int a[100],n,i,j=0,temp;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    for(i=0;i<n;i++)
    {
        if(a[i]!=0)
        {
            temp=a[i];
            a[i]=a[j];
            a[j]=temp;
            j++;
        }
    }

    for(i=0;i<n;i++)
        printf("%d ",a[i]);
}
