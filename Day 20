/* Question 77 : Matrix Multiplication */

#include<stdio.h>

void main()
{
    int a[10][10],b[10][10],c[10][10];
    int r1,c1,r2,c2,i,j,k;

    scanf("%d%d",&r1,&c1);
    scanf("%d%d",&r2,&c2);

    for(i=0;i<r1;i++)
        for(j=0;j<c1;j++)
            scanf("%d",&a[i][j]);

    for(i=0;i<r2;i++)
        for(j=0;j<c2;j++)
            scanf("%d",&b[i][j]);

    for(i=0;i<r1;i++)
    {
        for(j=0;j<c2;j++)
        {
            c[i][j]=0;
            for(k=0;k<c1;k++)
                c[i][j]+=a[i][k]*b[k][j];
        }
    }

    for(i=0;i<r1;i++)
    {
        for(j=0;j<c2;j++)
            printf("%d ",c[i][j]);
        printf("\n");
    }
}

/* Question 78 : Check Symmetric Matrix */

#include<stdio.h>

void main()
{
    int a[10][10];
    int n,i,j,flag=1;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&a[i][j]);

    for(i=0;i<n;i++)
    {
        for(j=0;j<n;j++)
        {
            if(a[i][j]!=a[j][i])
                flag=0;
        }
    }

    if(flag)
        printf("Symmetric Matrix");
    else
        printf("Not Symmetric Matrix");
}
/* Question 79 : Find Row-wise Sum */

#include<stdio.h>

void main()
{
    int a[10][10];
    int r,c,i,j,sum;

    scanf("%d%d",&r,&c);

    for(i=0;i<r;i++)
    {
        for(j=0;j<c;j++)
            scanf("%d",&a[i][j]);
    }

    for(i=0;i<r;i++)
    {
        sum=0;

        for(j=0;j<c;j++)
            sum=sum+a[i][j];

        printf("Row %d Sum = %d\n",i+1,sum);
    }
}

/* Question 80 : Find Column-wise Sum */

#include<stdio.h>

void main()
{
    int a[10][10];
    int r,c,i,j,sum;

    scanf("%d%d",&r,&c);

    for(i=0;i<r;i++)
    {
        for(j=0;j<c;j++)
            scanf("%d",&a[i][j]);
    }

    for(j=0;j<c;j++)
    {
        sum=0;

        for(i=0;i<r;i++)
            sum=sum+a[i][j];

        printf("Column %d Sum = %d\n",j+1,sum);
    }
}
